# Kernel module compression -- Alpine's kmod/modprobe expect
# zstd-compressed modules; kernel menuconfig does not enable this as a
# dependency of building a module, so anything that adds a loadable
# module (a wifi driver, any other recipe) needs this applied too. See
# docs/kernel-customization.md.
#
# Not on by default in a stock target -- a base image that never loads a
# module shouldn't carry a deviation from stock nobody asked for.
CONFIG_MODULE_COMPRESS=y
CONFIG_MODULE_COMPRESS_ZSTD=y
