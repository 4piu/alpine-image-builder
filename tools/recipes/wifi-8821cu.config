# RTL8821CU USB wifi. Mainlined driver: drivers/net/wireless/realtek/rtw88.
# See tools/recipes/README.md for how to use this, and
# docs/kernel-customization.md for background.
#
# Kconfig's own `select` statements pull in RTW88_CORE/RTW88_USB/
# RTW88_8821C/MAC80211/CFG80211 automatically once RTW88_8821CU is
# enabled -- this fragment only needs to set the leaf symbol (and
# CONFIG_USB, in case a minimal target hasn't already turned on USB host
# support). merge_config.sh reports if a requested symbol doesn't stick
# because of an unmet dependency stock sunxi_defconfig doesn't already
# satisfy -- review that output, and the resulting diff, before building.
CONFIG_USB=y
CONFIG_RTW88_8821CU=m

# This adds a loadable module -- also apply the zstd-modules recipe
# (tools/recipes/apply-recipes.sh <dest> wifi-8821cu zstd-modules) or the
# driver won't actually load. See docs/kernel-customization.md.
