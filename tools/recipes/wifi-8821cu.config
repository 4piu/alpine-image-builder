# RTL8821CU USB wifi. Mainlined driver: drivers/net/wireless/realtek/rtw88.
# See tools/recipes/README.md for how to use this, and
# docs/kernel-customization.md for background.
#
# RTW88_8821CU is nested behind a chain of `menuconfig X ... if X` blocks,
# none of which `select` reaches (select only pulls in the symbols
# *inside* the if-block it's declared in, never the block's own gate):
#   net/Kconfig:                  menuconfig WIRELESS, default y --
#                                  but sunxi_defconfig explicitly ships
#                                  `# CONFIG_WIRELESS is not set`
#     if WIRELESS: CFG80211, MAC80211 (depends on CFG80211)
#   drivers/net/wireless/Kconfig: menuconfig WLAN, default y -- same
#                                  story, sunxi_defconfig turns it off
#     if WLAN: .../realtek/Kconfig -> rtw88/Kconfig's `menuconfig RTW88`
#       if RTW88: RTW88_8821CU (select only reaches RTW88_CORE/
#                                RTW88_USB/RTW88_8821C from here)
# Every gate in that chain has to be requested explicitly, or
# olddefconfig treats the nearest unsatisfied `if` as false and silently
# drops everything below it -- Kconfig's own `default y` doesn't help
# once a defconfig explicitly turns a gate off, as sunxi_defconfig does.
# CONFIG_USB is already on in the stock defconfig; listed here anyway so
# this fragment is self-contained if that ever changes upstream.
# merge_config.sh reports if a requested symbol doesn't stick because of
# an unmet dependency -- review that output, and the resulting diff,
# before building.
CONFIG_WIRELESS=y
CONFIG_WLAN=y
CONFIG_CFG80211=m
CONFIG_MAC80211=m
CONFIG_RTW88=m
CONFIG_USB=y
CONFIG_RTW88_8821CU=m

# Not the same thing as the module-compression story in
# docs/kernel-customization.md (CONFIG_MODULE_COMPRESS*/
# CONFIG_MODULE_DECOMPRESS, for .ko files -- deliberately NOT set
# anywhere in this repo, see that doc). This is a separate subsystem:
# request_firmware()'s own decompressor, for *firmware blobs*, not
# kernel modules. It's needed here because Alpine's linux-firmware-rtw88
# package (see this recipe's packages.txt) ships its files pre-
# compressed as e.g. rtw88/rtw8821c_fw.bin.zst rather than plain
# rtw8821c_fw.bin -- confirmed on real hardware: without this,
# modprobe rtw88_8821cu fails ("Direct firmware load for
# rtw88/rtw8821c_fw.bin failed with error -2") because the driver asks
# for the plain filename and nothing decompresses the .zst for it.
CONFIG_FW_LOADER_COMPRESS=y
CONFIG_FW_LOADER_COMPRESS_ZSTD=y
