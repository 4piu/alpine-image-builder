# Orange Pi Zero 3 (Allwinner H618)

# Board-specific facts — no generic default exists for these.
UBOOT_BOARD_DEFCONFIG=orangepi_zero3
KERNEL_DT_FILE=allwinner/sun50i-h618-orangepi-zero3.dtb

# First arm64 target -- these differ from the armv7/H3 targets (ARCH,
# CROSS_COMPILE, ALPINE_ARCH, KERNEL_DEFCONFIG all change per SoC/arch).
# Still Allwinner-sunxi platform underneath, so UBOOT_WRITE_OFFSET and
# the u-boot-sunxi-with-spl.bin output convention stay the same as H3.
ARCH=arm64
CROSS_COMPILE=aarch64-linux-gnu-
ALPINE_ARCH=aarch64
# arch/arm64/configs/ has no per-board "sunxi_defconfig" the way
# arch/arm/configs/ does for 32-bit -- CONFIG_ARCH_SUNXI is already
# default y in the one generic arm64 defconfig.
KERNEL_DEFCONFIG=defconfig
UBOOT_WRITE_OFFSET=8
KERNEL_VERSION=v6.18
UBOOT_VERSION=v2026.07
ALPINE_VERSION=v3.24
