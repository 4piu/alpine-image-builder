# Onboard AW859A wifi/BT (a packaged Unisoc UWE5622/sc2355 chip) --
# see target/README.md and patches/ for this target. Mainline Linux has
# no driver and no devicetree node for this chip at all (not a gap in
# this project's config -- confirmed by inspecting both drivers/net/
# wireless/ and this board's own upstream DTS); patches/ vendors an
# out-of-tree driver (Xunlong's downstream source + Armbian's kernel-
# version compat patches, both real projects that already maintain
# this) and wires it into Kbuild as a normal in-tree driver so it's
# configured the same way as everything else here -- via this file.
#
# Base gates -- arm64's generic defconfig already ships these =y/=m,
# but every gate is listed explicitly anyway: olddefconfig silently
# drops anything below the first unsatisfied `if` in a Kconfig menu,
# so a fragment that only sets the leaf symbol is one defconfig change
# away from silently losing wifi. See docs/kernel-customization.md.
CONFIG_WIRELESS=y
CONFIG_WLAN=y
CONFIG_CFG80211=m
CONFIG_RFKILL=m

# The vendored driver itself (patches/0001, patches/0002). Selecting
# SPARD_WLAN_SUPPORT pulls in SUNXI_WIFI_DEVICE_UWE5622 (see
# unisocwcn/Kconfig) -- the devicetree-parsing build variant added by
# patches/0001, not Xunlong's original AW_WIFI_DEVICE_UWE5622 path,
# which calls into Allwinner's own downstream sunxi-wlan.c platform
# glue that isn't vendored here (and isn't in mainline either).
CONFIG_SPARD_WLAN_SUPPORT=y
CONFIG_WLAN_UWE5622=m
CONFIG_SPRDWL_NG=m
CONFIG_TTY_OVERY_SDIO=m

# Deliberately NOT setting CONFIG_MODULE_COMPRESS*/CONFIG_MODULE_DECOMPRESS
# here. insmod/modprobe don't care whether a .ko is compressed -- that
# was a wrong assumption baked into an earlier version of this file and
# of docs/kernel-customization.md. The kernel's own in-kernel zstd
# decompressor (needed to read .ko.zst back) is a separate, more
# constrained implementation than a real zstd binary: confirmed on real
# hardware, it rejected a valid zstd-compressed module (verified intact
# with a real `zstd -t`) with "Invalid ELF header magic: != ELF",
# nondeterministically by module, and took eth0 down along with it.
# Plain uncompressed .ko files just work -- see
# docs/kernel-customization.md.
