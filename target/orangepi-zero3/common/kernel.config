# Onboard AW859A wifi/BT (a packaged Unisoc UWE5622/sc2355 chip) --
# see target/README.md and patches/ for this target. Mainline Linux has
# no driver and no devicetree node for this chip at all (not a gap in
# this project's config -- confirmed by inspecting both drivers/net/
# wireless/ and this board's own upstream DTS); patches/ vendors the
# driver from armbian/build's patch/misc/wireless-uwe5622/ (Xunlong's
# downstream source plus Armbian's own bugfix/compat patch chain --
# see notes/armbian-kernel-patches-brainstorm.md's case study) and
# wires it into Kbuild as a normal in-tree driver so it's configured
# the same way as everything else here -- via this file.
#
# Base gates -- arm64's generic defconfig already ships these =y/=m,
# but every gate is listed explicitly anyway: olddefconfig silently
# drops anything below the first unsatisfied `if` in a Kconfig menu,
# so a fragment that only sets the leaf symbol is one defconfig change
# away from silently losing wifi. See docs/kernel-customization.md.
CONFIG_WIRELESS=y
CONFIG_WLAN=y
CONFIG_CFG80211=m
CONFIG_RFKILL=m

# The vendored driver itself (patches/armbian-0001, patches/0002).
# Selecting SPARD_WLAN_SUPPORT pulls in AW_WIFI_DEVICE_UWE5622 and
# AW_BIND_VERIFY (see drivers/net/wireless/uwe5622/Kconfig, added by
# armbian-0001 -- Armbian's own real board-variant symbol, not this
# project's former custom CONFIG_SUNXI_WIFI_DEVICE_UWE5622, which
# doesn't exist in Armbian's driver source and has been dropped).
# AW_WIFI_DEVICE_UWE5622's own Makefile section defaults to expecting
# Allwinner's own downstream sunxi-wlan.c platform glue instead of
# parsing the devicetree node this target's overlay provides --
# patches/post-armbian-0001-enable-dt-parsing-for-aw-wifi-device.patch
# (this project's own adaptation, not from Armbian) flips that one
# line. Set explicitly below rather than relying on the `select` chain
# alone, same "every gate explicit" reasoning as the rest of this file.
CONFIG_SPARD_WLAN_SUPPORT=y
CONFIG_AW_WIFI_DEVICE_UWE5622=y
CONFIG_WLAN_UWE5622=m
CONFIG_SPRDWL_NG=m
CONFIG_TTY_OVERY_SDIO=m

# Armbian's own build defaults for this driver, confirmed by reading
# drivers/net/wireless/uwe5622/unisocwcn/Makefile's AW_WIFI_DEVICE_UWE5622
# section directly rather than assumed -- CONFIG_CHECK_DRIVER_BY_CHIPID
# and both ADMA directions are hardcoded ccflags-y in that Makefile
# section (not Kconfig symbols this file can set), so nothing to add
# here; recorded so a future reader doesn't go looking for them as
# missing kernel.config lines.

# Deliberately NOT setting CONFIG_MODULE_COMPRESS*/CONFIG_MODULE_DECOMPRESS
# here. insmod/modprobe don't care whether a .ko is compressed -- that
# was a wrong assumption baked into an earlier version of this file and
# of docs/kernel-customization.md. The kernel's own in-kernel zstd
# decompressor (needed to read .ko.zst back) is a separate, more
# constrained implementation than a real zstd binary: confirmed on real
# hardware, it rejected a valid zstd-compressed module (verified intact
# with a real `zstd -t`) with "Invalid ELF header magic: != ELF",
# nondeterministically by module, and took eth0 down along with it.
# Plain uncompressed .ko files just work -- see
# docs/kernel-customization.md.
