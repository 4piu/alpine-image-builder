 	/* When this quirk is set, HCI_OP_SET_EVENT_FLT requests with
 	 * HCI_FLT_CLEAR_ALL are ignored and event filtering is
 	 * completely avoided. A subset of the CSR controller
diff --git a/net/bluetooth/hci_sync.c b/net/bluetooth/hci_sync.c
index 6e76798ec..815c8e65a 100644
--- a/net/bluetooth/hci_sync.c
+++ b/net/bluetooth/hci_sync.c
@@ -4196,6 +4196,19 @@ static int hci_setup_link_policy_sync(struct hci_dev *hdev)
 	if (!(hdev->commands[5] & 0x10))
 		return 0;
 
+	/*
+	 * Some controllers (confirmed on a Spreadtrum/Unisoc uwe5622)
+	 * advertise link-policy features (RSWITCH/HOLD/SNIFF/PARK) in
+	 * their LMP feature bits that the firmware doesn't actually
+	 * implement -- Write Default Link Policy Settings fails with
+	 * "Invalid HCI Command Parameters" (-22) for any non-zero
+	 * policy value, not just PARK alone. Skip the command entirely
+	 * rather than guessing which subset of the advertised bits is
+	 * real.
+	 */
+	if (hci_test_quirk(hdev, HCI_QUIRK_BROKEN_LINK_POLICY))
+		return 0;
+
 	memset(&cp, 0, sizeof(cp));
 
