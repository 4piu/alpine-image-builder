diff --git a/drivers/bluetooth/hci_ldisc.c b/drivers/bluetooth/hci_ldisc.c
index d0adae326..51a4eea2e 100644
--- a/drivers/bluetooth/hci_ldisc.c
+++ b/drivers/bluetooth/hci_ldisc.c
@@ -666,6 +666,21 @@ static int hci_uart_register_dev(struct hci_uart *hu)
 	hdev->setup = hci_uart_setup;
 	SET_HCIDEV_DEV(hdev, hu->tty->dev);
 
+	/*
+	 * Spreadtrum/Unisoc (sprd) combo wifi/BT chips (uwe5622 and
+	 * siblings) expose their controller as an "ttyBT*" tty (see
+	 * tty-sdio/sprdbt_tty.c) and declare RSWITCH/HOLD/SNIFF/PARK
+	 * link-policy support in their LMP features, but
+	 * HCI_OP_WRITE_DEF_LINK_POLICY fails on real hardware ("Opcode
+	 * 0x080f failed: -22", blocking hci_dev_open entirely) for any
+	 * non-zero policy value -- confirmed by testing with only PARK
+	 * masked out first (still failed identically), so this isn't a
+	 * single-bit problem, the command just isn't implemented at all
+	 * despite the advertised features.
+	 */
+	if (hu->tty->driver && !strncmp(hu->tty->driver->name, "ttyBT", 5))
+		hci_set_quirk(hdev, HCI_QUIRK_BROKEN_LINK_POLICY);
+
 	if (test_bit(HCI_UART_RAW_DEVICE, &hu->hdev_flags))
 		hci_set_quirk(hdev, HCI_QUIRK_RAW_DEVICE);
 
