/*
 * Enables the onboard AW859A (Unisoc UWE5622) wifi/BT combo chip --
 * see target/README.md and common/patches/ for this target for
 * the driver itself; this overlay is just the devicetree side.
 *
 * GPIO assignments below come from decompiling the device tree baked
 * into Orange Pi's own official firmware for this exact board -- not
 * guessed or copied from a different board -- since mainline's own
 * DTS for this board has never wired this chip up at all (see
 * target/README.md for why).
 *
 * wl-reg-on (PG18) is owned by mmc1's own mmc-pwrseq-simple, not by
 * the "unisoc,uwe_bsp" platform node below -- a first real-hardware
 * boot without it failed with "mmc1: Failed to initialize a
 * non-removable card": mmc1 only scans for its (non-removable) card
 * once, at boot, and nothing had powered the chip on by then --
 * uwe_bsp's own chip_power_on() (wcn_boot.c) only runs later, when
 * wifi is actually brought up by userspace, which is far too late for
 * mmc1's one-shot scan. mmc-pwrseq-simple powers the chip up as part
 * of mmc1's own probe, before that scan happens, which is exactly
 * what it's for. Same fix, same GPIO, and the same GPIO_ACTIVE_LOW
 * polarity (RST_N is a real active-low reset line) as the sibling
 * Zero2's own upstream, already-working sun50i-h616-orangepi-zero.dtsi
 * -- not a guess. uwe_bsp no longer requests this GPIO itself; its own
 * code already treats a missing/invalid wl-reg-on as "something else
 * owns power" and just skips managing it.
 *
 * pub-int-gpio (PG15, "wlan hostwake" on the real firmware's DT) is
 * deliberately NOT wired up here, and that's confirmed, not a gap:
 * a first real-hardware boot with it set caused an interrupt storm
 * (sdio_pub_int_init() arms it immediately in marlin_probe(), well
 * before the chip has even been through its power-up/firmware-load
 * sequence -- with nothing yet driving the line to a real level, it
 * free-runs, hundreds of thousands of "sdio cmd52 fail"/irq_cnt
 * lines a second). The driver already treats this GPIO as optional
 * (every use is behind `if (marlin_dev->int_ap > 0)`), so omitting
 * it is a clean, supported way to disable this "public interrupt"/
 * wake-source feature, not a workaround. bt-wake-host-gpio (PG16) is
 * a separate, unrelated line and unaffected.
 *
 * Both fragments target by path (/soc/mmc@4021000, confirmed as
 * mmc1 from this board's own compiled dtb, matching both the real
 * firmware's decompiled DT and the sibling Zero2's upstream one),
 * not by label, even though patches/0003-enable-dtc-symbols-for-
 * overlay.patch does give the base dtb a real symbol table now --
 * that patch exists for the uwe-bsp node's own sdhci-name = <&mmc1>
 * property below, which does need it. No need to also switch the
 * fragment targets themselves over; target-path already works.
 */
/dts-v1/;
/plugin/;

#include <dt-bindings/gpio/gpio.h>

/ {
	compatible = "xunlong,orangepi-zero3", "allwinner,sun50i-h618";

	fragment@0 {
		target-path = "/soc/mmc@4021000";
		__overlay__ {
			bus-width = <4>;
			non-removable;
			mmc-pwrseq = <&wifi_pwrseq>;
			/*
			 * Dedicated onboard wifi regulators, not reg_dldo1 --
			 * an earlier version of this overlay used reg_dldo1
			 * (a fixed-3.3V PMIC rail) for both vmmc and vqmmc,
			 * on the assumption this board has no separate wifi
			 * supplies. That was wrong, confirmed by decompiling
			 * Armbian's own live devicetree on this exact board:
			 * it wires vmmc to a dedicated vcc33-wifi (3.3V) and
			 * vqmmc to a dedicated vcc-wifi-io (1.8V) -- two
			 * always-on fixed regulators private to the wifi
			 * module, both declared in fragment@1 below, chained
			 * off reg_vcc5v the same way Armbian's does. Running
			 * vqmmc at reg_dldo1's fixed 3.3V instead of the real
			 * 1.8V I/O rail didn't stop the SDIO card from
			 * scanning or answering short register reads, but
			 * reliably broke actual firmware-download bulk
			 * writes ("not have card" mid-transfer) -- signal
			 * levels marginal enough to pass light traffic but
			 * not sustained DMA writes. vmmc alone (not vqmmc)
			 * is what mmc_regulator_get_supply() (drivers/mmc/
			 * core/regulator.c) uses to compute host->ocr_avail;
			 * leaving either supply unset entirely reintroduces
			 * the earlier "no support for card's volts" failure.
			 */
			vmmc-supply = <&reg_vcc33_wifi>;
			vqmmc-supply = <&reg_vcc_wifi_io>;
			status = "okay";
		};
	};

	fragment@1 {
		target-path = "/";
		__overlay__ {
			/* SOC pad -- none, always-on onboard LDO */
			reg_vcc33_wifi: vcc33-wifi {
				compatible = "regulator-fixed";
				regulator-name = "vcc33-wifi";
				regulator-min-microvolt = <3300000>;
				regulator-max-microvolt = <3300000>;
				regulator-always-on;
				vin-supply = <&reg_vcc5v>;
			};

			/*
			 * Stepped down from vcc33-wifi by a second
			 * always-on onboard LDO -- matches Armbian's
			 * vcc-wifi-io exactly (same vin-supply chain,
			 * same fixed 1.8V), not a PMIC channel.
			 */
			reg_vcc_wifi_io: vcc-wifi-io {
				compatible = "regulator-fixed";
				regulator-name = "vcc-wifi-io";
				regulator-min-microvolt = <1800000>;
				regulator-max-microvolt = <1800000>;
				regulator-always-on;
				vin-supply = <&reg_vcc33_wifi>;
			};

			wifi_pwrseq: wifi-pwrseq {
				compatible = "mmc-pwrseq-simple";
				clocks = <&rtc 1>;
				clock-names = "osc32k-out";
				/* SOC pad PG18, module pad RST_N */
				reset-gpios = <&pio 6 18 GPIO_ACTIVE_LOW>;
				post-power-on-delay-ms = <200>;
			};

			/*
			 * Node name matters here, separately from
			 * "compatible": unisocwcn/sdio/sdiohal_main.c's
			 * sdiohal_parse_dt() looks this node up by literal
			 * name (of_find_node_by_name(NULL, "uwe-bsp")), not
			 * by compatible string -- that's a completely
			 * different, driver-internal lookup from the one the
			 * "unisoc,uwe_bsp" platform driver itself uses to
			 * match this node. Naming it anything else (e.g.
			 * "uwe5622-bsp") makes that lookup silently fail,
			 * leaving irq_type/gpio_num and friends at their
			 * zero-initialized defaults -- request_irq(0, ...)
			 * failing with -EINVAL ("request irq err gpio is 0")
			 * is what that looks like on real hardware; it is
			 * not a GPIO/pwrseq problem despite the symptom.
			 */
			uwe5622_bsp: uwe-bsp {
				compatible = "unisoc,uwe_bsp";
				/*
				 * Without this, sdiohal_parse_dt()
				 * (unisocwcn/sdio/sdiohal_main.c) can't
				 * resolve the mmc_host behind this chip
				 * (sdiohal_dev_get_host() gets a NULL node
				 * and fails), so sdiohal_parse_dt() returns
				 * -1 and sdiohal_init() bails out *before*
				 * ever calling sdiohal_misc_init() --
				 * silently skipping sdiohal_sleep_flag_init(),
				 * which is the only place flag_resume ever
				 * gets set to 1. Confirmed on real hardware
				 * by direct instrumentation: with this
				 * property missing, flag_resume stays 0 for
				 * the entire boot, so every single SDIO
				 * register access pays sdiohal_resume_check()'s
				 * full ~30s spin-wait (5000 retries of
				 * usleep_range(4000,6000), never satisfied,
				 * then proceeding anyway) before the driver's
				 * own POWERUP_WAIT_MS watchdog gives up first
				 * and kills the connection outright -- not a
				 * firmware, power-rail, or ADMA problem, just
				 * this one missing phandle.
				 */
				sdhci-name = <&mmc1>;
				/*
				 * In-band SDIO IRQ (the mmc1 node already
				 * has cap-sdio-irq) instead of a dedicated
				 * external GPIO line -- matches the
				 * CONFIG_SDIO_INBAND_INT build flag's intent,
				 * but sdiohal_parse_dt() (unisocwcn/sdio/
				 * sdiohal_main.c) only honors that flag when
				 * CONFIG_WCN_PARSE_DTS is *off*; when it's on
				 * (our case), a "data-irq"/"rx-polling"
				 * property on *this* node unconditionally
				 * overrides it, defaulting to an external-IRQ
				 * mode that then reads a nonexistent
				 * "sdio-ext-int-gpio" property and fails with
				 * request_irq(0, ...) -- not present here on
				 * purpose, so this property is required, not
				 * redundant with the build flag.
				 */
				data-irq;
				/* SOC pad PG19, module pad NC */
				bt-reg-on = <&pio 6 19 GPIO_ACTIVE_LOW>;
				bt-wake-host;
				/* SOC pad PG16, module pad INT */
				bt-wake-host-gpio = <&pio 6 16 GPIO_ACTIVE_HIGH>;
				status = "okay";
			};
		};
	};
};
