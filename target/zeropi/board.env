# ZeroPi (Allwinner H3)

# Board-specific facts — no generic default exists for these.
UBOOT_BOARD_DEFCONFIG=zeropi
KERNEL_DT_FILE=allwinner/sun8i-h3-zeropi.dtb

# Currently identical across every target here (there's only one SoC
# family supported so far) — see target/README.md for why these stay as
# plain fields instead of a shared SoC-layer file.
ARCH=arm
CROSS_COMPILE=arm-none-eabi-
ALPINE_ARCH=armv7
KERNEL_DEFCONFIG=sunxi_defconfig
UBOOT_WRITE_OFFSET=8
KERNEL_VERSION=v6.18
UBOOT_VERSION=v2026.07
ALPINE_VERSION=v3.24
